# NextAuth (v5) required env
# Generate a strong secret: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
AUTH_SECRET=

# Public URL of your app (used for callbacks)
# e.g. http://localhost:3000 in dev, https://your-domain.com in prod
AUTH_URL=
# Needed for NextAuth behind proxies or in dev containers
AUTH_TRUST_HOST=true

# Feature flags
# Enable NextAuth middleware protection (route guarding)
AUTH_MIDDLEWARE_ENABLED=true
# Keep legacy localStorage session bridge during migration
NEXT_PUBLIC_AUTH_LEGACY_BRIDGE=true

# AI assistant (Vercel AI SDK)
# Only one provider is active per deployment. Keep AI_PROVIDER aligned with the
# provider block below and leave the other provider block empty.
AI_PROVIDER=google

# Active provider: Google Gemini
GOOGLE_GENERATIVE_AI_MODEL=gemini-3-flash-preview
GOOGLE_GENERATIVE_AI_API_KEY=
# Optional key pool for rotation; leave empty unless you intentionally use multiple keys.
# GOOGLE_GENERATIVE_AI_API_KEYS=

# Active provider alternative: Groq
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=
# Optional key pool for rotation; leave empty unless you intentionally use multiple keys.
# GROQ_API_KEYS=

# Optional future provider placeholders
ANTHROPIC_API_KEY=
AI_GATEWAY_API_KEY=

# AI guardrails (Task 1B)
# Output quality
AI_MAX_OUTPUT_TOKENS=2048
AI_MAX_TOOL_STEPS=5
# Context limits
AI_MAX_MESSAGES=40
AI_MAX_INPUT_CHARS=40000
# Rate limit (anti-abuse)
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX_REQUESTS=10
# Daily quota (cost control) — adjust per org size
AI_DAILY_USER_QUOTA_REQUESTS=150
AI_DAILY_TENANT_QUOTA_REQUESTS=1500
