# qltbyt-backup environment file
#
# Production location: /etc/qltbyt-backup/.env  (mode 0600, owner root)
# Setup runbook      : docs/runbooks/db-backup-setup.md
# Script             : scripts/backup-db.sh
#
# DO NOT commit a filled-in copy of this file. This template only.

# ─── Database connection ────────────────────────────────────────────────
#
# IMPORTANT: use the DIRECT connection string, NOT the pooler/Supavisor URL.
#
# Where to find it:
#   Supabase Dashboard → Project Settings → Database
#   → "Connection string" → tab "URI"
#   → mode "Direct connection"  (port 5432, host db.<ref>.supabase.co)
#
# Why not the pooler?
#   - Transaction-mode pooler (port 6543) does NOT support pg_dump.
#   - Session-mode pooler has aggressive idle timeout that can break
#     long-running dumps.
#   - Direct connection works for any DB size and is what Supabase
#     recommends for backup tooling.
#
# Network note:
#   db.<ref>.supabase.co resolves IPv6-only by default. If the VPS does
#   NOT have IPv6, either enable Supabase's IPv4 add-on or use the
#   Supavisor SESSION mode endpoint (NOT transaction mode).
#
DATABASE_URL="postgresql://postgres:REPLACE_PASSWORD@db.cdthersvldpnlbvpufrr.supabase.co:5432/postgres?sslmode=require"

# ─── Google Drive (rclone) ──────────────────────────────────────────────
#
# Format: <remote_name>:<folder_path>
#
# `<remote_name>` must match a remote configured in `rclone config`
# (verify with `rclone listremotes`). The folder is created on first
# upload if it does not exist.
#
RCLONE_REMOTE="gdrive:qltbyt-backup"

# ─── Telegram alerts ────────────────────────────────────────────────────
#
# How to get the values:
#   1. Talk to @BotFather → /newbot → save TOKEN
#   2. Send any message to your new bot from your account/group
#   3. curl "https://api.telegram.org/bot<TOKEN>/getUpdates"
#      → take the chat.id (negative starts with -100 for groups)
#
# Failure alerts are sent unconditionally. Set TG_HEARTBEAT=1 to also
# send a ✅ message on every successful run (useful for the first week).
#
TG_TOKEN="REPLACE_TOKEN"
TG_CHAT="REPLACE_CHAT_ID"
TG_HEARTBEAT=0

# ─── Retention ──────────────────────────────────────────────────────────
#
# Number of days to keep backups in Drive. Older objects are deleted
# at the end of each successful run.
#
RETAIN_DAYS=7

# Optional: directory for per-run stderr capture and latest upload
# diagnostics. Default: /var/log/qltbyt-backup
# BACKUP_DETAIL_DIR="/var/log/qltbyt-backup"

# ─── Schemas to dump ────────────────────────────────────────────────────
#
# Comma-separated list (no spaces). Default covers everything that
# matters for this app:
#
#   public               - app data + RPC functions (175+ SECURITY DEFINER)
#   auth                 - Supabase auth schema (currently 0 rows in this
#                          project, but future-proofed)
#   storage              - Supabase storage metadata (currently empty)
#   supabase_migrations  - migration tracking — REQUIRED for fresh-project
#                          restore so MCP `apply_migration` knows what's
#                          already applied.
#
DUMP_SCHEMAS="public,auth,storage,supabase_migrations"
